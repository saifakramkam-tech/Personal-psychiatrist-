import torch
from transformers import AutoModelForCausalLM, AutoTokenizer

# -------------------------------------------------
# 1️⃣  Device / dtype handling
# -------------------------------------------------
if torch.cuda.is_available():
    device = torch.device("cuda")
    dtype  = torch.float16          # half‑precision works on GPU
else:
    device = torch.device("cpu")
    dtype  = torch.float32          # fallback for CPU

# -------------------------------------------------
# 2️⃣  Load model & tokenizer
# -------------------------------------------------
model_name = "meta-llama/Llama-2-7b-chat-hf"

tokenizer = AutoTokenizer.from_pretrained(model_name)
# Llama‑2 has no pad token → reuse EOS as pad
tokenizer.pad_token = tokenizer.eos_token

model = AutoModelForCausalLM.from_pretrained(
    model_name,
    torch_dtype=dtype,
    device_map="auto",
)
model.to(device)
model.eval()  # disable dropout etc.

# -------------------------------------------------
# 3️⃣  System prompt (kept short for UI space)
# -------------------------------------------------
SYSTEM_PROMPT = """You are a caring, empathetic friend.
Keep replies brief (1‑2 sentences). Mirror tone, add gentle humor if sad.
Never give medical advice; suggest professional help when needed.
"""

# -------------------------------------------------
# 4️⃣  Helper: move every tensor in a dict to `device`
# -------------------------------------------------
def _to_device(batch, device):
    return {k: v.to(device) for k, v in batch.items()}

# -------------------------------------------------
# 5️⃣  Safety filter placeholder (replace with real API)
# -------------------------------------------------
def safe_filter(text: str) -> str:
    """Very light profanity filter – replace with NVIDIA content‑filter."""
    banned = ["badword1", "badword2"]   # extend as needed
    for w in banned:
        text = text.replace(w, "***")
    return text

# -------------------------------------------------
# 6️⃣  Core generation routine
# -------------------------------------------------
def generate_reply(user_text: str, emotion_label: str) -> str:
    # ---- emotion‑based suffix ----
    suffix = {
        "sad": "I’m sorry you’re feeling down. Here’s a little smile 😊",
        "angry": "I hear you. Let’s take a breath together.",
        "neutral": "",
        "happy": "That’s wonderful! Keep the good vibes."
    }.get(emotion_label, "")

    # ---- build the full prompt ----
    prompt = f"{SYSTEM_PROMPT}\nUser: {user_text}\nAssistant: {suffix}"
    inputs = tokenizer(prompt, return_tensors="pt", truncation=True, max_length=1024)
    inputs = _to_device(inputs, device)

    # ---- generation (no grad, stop at EOS) ----
    with torch.no_grad():
        output_ids = model.generate(
            **inputs,
            max_new_tokens=30,
            do_sample=True,
            temperature=0.7,
            top_p=0.9,
            pad_token_id=tokenizer.pad_token_id,
            eos_token_id=tokenizer.eos_token_id,
        )

    # ---- decode & post‑process ----
    full_text = tokenizer.decode(output_ids[0], skip_special_tokens=True)

    # Remove the prompt part we fed in
    if suffix:
        start_idx = full_text.find(suffix) + len(suffix)
        generated = full_text[start_idx:].strip()
    else:
        generated = full_text.split("Assistant:")[-1].strip()

    # Keep only the first two sentences
    sentences = generated.split(". ")
    short_reply = ". ".join(sentences[:2])
    if not short_reply.endswith("."):
        short_reply += "."

    # ---- safety filter ----
    short_reply = safe_filter(short_reply)

    return short_reply


# -------------------------------------------------
# 7️⃣  Example usage
# -------------------------------------------------
if __name__ == "__main__":
    user_msg = "I feel really down today."
    emotion = "sad"   # normally from an external classifier
    print(generate_reply(user_msg, emotion))
